{
  "description": "the-rewrite-room: validate STATUS block contract on rewrite-room agent stop",
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "^rewrite-room-",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-status-block.cjs\"",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
