{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.cjs\"",
        "description": "Register new Claude Code session with dot-dash server"
      }
    ],
    "SessionEnd": [
      {
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-stop.cjs\"",
        "description": "Deregister session from dot-dash server"
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/prompt-injector.cjs\"",
        "description": "Check injection queue and prepend queued message to user prompt"
      }
    ]
  }
}
