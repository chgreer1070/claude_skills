{
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "^(file-summarizer|url-summarizer|image-summarizer)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-summarizer-output.cjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
