{
  "enabledPlugins": {
    "python3-development@jamie-bitflight-skills": true,
    "holistic-linting@jamie-bitflight-skills": true,
    "agent-orchestration@jamie-bitflight-skills": true,
    "plugin-creator@jamie-bitflight-skills": true
  },
  "permissions": {
    "allow": [
      "Bash(gh issue list:*)",
      "Bash(git worktree:*)",
      "mcp__ref__*",
      "mcp__exa__*",
      "mcp__context7__*",
      "mcp__sequential-thinking__*"
    ],
    "deny": ["WebFetch", "WebSearch"]
  },
  "statusLine": {
    "type": "command",
    "command": "node $CLAUDE_PROJECT_DIR/sessions/statusline.js"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-rtica.js\""
          }
        ]
      }
    ]
  }
}
