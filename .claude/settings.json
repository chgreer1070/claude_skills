{
  "env": {
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Setup": [
      {
        "hooks": [
          {
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run-commands-try-all.cjs \"uv self update\" \"uv run prek install -t pre-commit -t commit-msg -t pre-rebase -t post-merge\"",
            "type": "command"
          }
        ],
        "matcher": "init|maintenance"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(gh issue list:*)",
      "Bash(git worktree:*)",
      "Glob",
      "Grep",
      "Read",
      "Write",
      "Edit",
      "mcp__ref__*",
      "mcp__exa__*",
      "mcp__context7__*",
      "mcp__sequential-thinking__*",
      "mcp__plugin_dh_backlog__*",
      "mcp__plugin_dh_sam__*",
      "mcp__plugin_context-mode_context-mode__*",
      "Bash(bc:*)",
      "Bash(diffstat:*)",
      "Bash(npm:*)",
      "Bash(bd:*)",
      "Bash(mkdir:*)",
      "Bash(uv run prek:*)",
      "Bash(uvx skilllint:*)",
      "Bash(uv run fastmcp:*)",
      "mcp__claude-in-chrome__read_console_messages"
    ],
    "deny": []
  }
}
