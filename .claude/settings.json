{
  "permissions": {
    "allow": [
      "Bash(gh issue list:*)",
      "Bash(git worktree:*)",
      "Glob",
      "Grep",
      "Read",
      "mcp__ref__*",
      "mcp__exa__*",
      "mcp__context7__*",
      "mcp__sequential-thinking__*",
      "mcp__backlog__*"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-rtica.cjs\""
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-backlog.cjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-backlog-reminder.cjs\""
          }
        ]
      }
    ],
    "Setup": [
      {
        "matcher": "init|maintenance",
        "hooks": [
          {
            "type": "command",
            "command": "uv run prek install"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "hallucination-detector@jamie-bitflight-skills": true,
    "superpowers-lab@superpowers-marketplace": true,
    "hookify@claude-plugins-official": true
  }
}
