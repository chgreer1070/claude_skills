{
  "permissions": {
    "allow": [
      "Bash(gh issue list:*)",
      "Bash(git worktree:*)",
      "Glob",
      "Grep",
      "Read",
      "mcp__ref__*",
      "mcp__exa__*",
      "mcp__context7__*",
      "mcp__sequential-thinking__*",
      "mcp__backlog__*",
      "mcp__plugin_context-mode_context-mode__*"
    ],
    "deny": []
  },
  "hooks": {
    "Setup": [
      {
        "matcher": "init|maintenance",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run-commands-try-all.cjs \"uv self update\" \"uv run prek install -t pre-commit -t commit-msg -t pre-rebase -t post-merge\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "hallucination-detector@jamie-bitflight-skills": true,
    "superpowers-lab@superpowers-marketplace": true
  }
}
