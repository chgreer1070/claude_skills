{
  "mcpServers": {
    "Ref-local": {
      "command": "node",
      "args": ["./scripts/npx-run.cjs", "-y", "ref-tools-mcp@latest"],
      "env": {
        "REF_API_KEY": "$REF_API_KEY"
      }
    },
    "context7-local": {
      "command": "node",
      "args": [
        "./scripts/npx-run.cjs",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "$CONTEXT7_API_KEY"
      ]
    },
    "backlog": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "plugins/development-harness",
        "python",
        "-m",
        "backlog_core.server"
      ]
    },
    "octocode": {
      "command": "npx",
      "args": ["-y", "octocode-mcp@latest"]
    }
  }
}
