{
    "mcpServers": {
        "Ref": {
            "command": "npx",
            "args": [
                "-y",
                "ref-tools-mcp@latest"
            ]
        },
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp",
                "--api-key",
                "$CONTEXT7_API_KEY"
            ]
        },
        "kernel": {
            "url": "https://mcp.onkernel.com/mcp",
            "headers": {
                "Authorization": "Bearer $KERNEL_API_KEY"
            }
        }
    }
}