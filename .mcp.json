{
  "mcpServers": {
    "Ref-local": {
      "command": "npx",
      "args": ["-y", "ref-tools-mcp@latest"],
      "env": {
        "REF_API_KEY": "$REF_API_KEY"
      }
    },
    "context7-local": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp", "--api-key", "$CONTEXT7_API_KEY"]
    },
    "kernel-local": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.onkernel.com/mcp", "--header", "Authorization: Bearer $KERNEL_API_KEY"]
    }
  }
}
