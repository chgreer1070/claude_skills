raw/

# Scratch space for agent output and temporary reports (not committed)
.tmp/
.cache*/
.*_cache/
.DS_Store
__pycache__
.venv
node_modules/
# Runtime context files (created by /start-task, cleaned by SubagentStop hook)
# DEPRECATED: context files are moving to ~/.dh/projects/{slug}/context-{session}/
# Kept here for backward compatibility during migration.
.claude/context/
# cc-sessions runtime files
sessions/sessions-state.json
sessions/package.json
sessions/transcripts/
sessions/.archived/
# Build artifacts
*.zip
.coverage*
# Code review reports
.claude/smells/
# Daily releases pipeline working directory (root only; not .claude/skills/daily-releases/)
/daily-releases/

# Agent research artifacts (intermediate analysis files)
**/analysis-*.md
**/comparative-analysis-*.md
**/synthesis-analysis.md

# Kaizen transcript analysis artifacts (may contain session excerpts and local paths)
.claude/kaizen/

# GitLab skill sync lock files
*/.sync-gitlab-docs.lock

# Claude Code scheduled tasks lock
.claude/scheduled_tasks.lock

# uv lock file (dependency management)
uv.lock

# Local settings with machine-specific paths
.claude/settings.local.json

# Private session discussion notes
**/session-notes/

!.claude/knowledge/workflow-diagrams
.env
package-lock.json
.hypothesis/

# Git worktrees
.worktrees/
.claude/worktrees/
.claude/agent-memory
.claude/agents/tests/

# LevelDB stores
*.db/
.claude/audits/
.cocoindex_code/

# DH state directories (Tier 2/3: persistent and ephemeral state moved to ~/.dh/)
# DEPRECATED: these in-repo directories are replaced by the three-tier DH state architecture.
# Ignored here so old-layout files do not appear as untracked during/after migration.
# New canonical locations: ~/.dh/projects/{slug}/backlog/, ~/.dh/projects/{slug}/plan/, etc.
.claude/backlog/
.claude/reports/
plan/
